# EmailJS credentials for the contact form.
# The configured EmailJS service must be connected to contact@pharmviah.com
# (Google Workspace mailbox via Gmail OAuth, or custom SMTP using smtp.gmail.com
# with a Gmail App Password).
#
# Get these values from https://dashboard.emailjs.com:
#   Service ID  -> Email Services
#   Template ID -> Email Templates (template's "To Email" must be contact@pharmviah.com)
#   Public Key  -> Account -> General -> API Keys
#
# Copy this file to .env and fill in real values. Do not commit .env.

VITE_EMAILJS_SERVICE_ID=service_m8juwtc
VITE_EMAILJS_TEMPLATE_ID=__ejs-test-mail-service__
VITE_EMAILJS_PUBLIC_KEY=OQPytgeTOJk8IQeNR
VITE_API_URL=https://pharmviah.com/